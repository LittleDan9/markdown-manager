{
  "uid": "mm-spell-check-down",
  "title": "MM Spell-Check Service Down",
  "ruleGroup": "MM - Services",
  "folderUID": "mm-alerts",
  "noDataState": "OK",
  "condition": "C",
  "for": "10m",
  "data": [
    {
      "refId": "A",
      "relativeTimeRange": { "from": 900, "to": 0 },
      "datasourceUid": "loki",
      "model": {
        "expr": "count_over_time({app=\"mm\", service=\"spell-check\"} [15m])",
        "queryType": "range"
      }
    },
    {
      "refId": "B",
      "relativeTimeRange": { "from": 0, "to": 0 },
      "datasourceUid": "__expr__",
      "model": {
        "type": "reduce",
        "expression": "A",
        "reducer": "last",
        "settings": { "mode": "replaceNN", "replaceWithValue": 0 }
      }
    },
    {
      "refId": "C",
      "relativeTimeRange": { "from": 0, "to": 0 },
      "datasourceUid": "__expr__",
      "model": {
        "type": "threshold",
        "expression": "B",
        "conditions": [
          { "evaluator": { "type": "lt", "params": [1] } }
        ]
      }
    }
  ],
  "labels": {
    "severity": "warning",
    "app": "mm",
    "service": "spell-check"
  },
  "annotations": {
    "summary": "MM spell-check service has produced no logs for >15 minutes — spell checking unavailable."
  }
}

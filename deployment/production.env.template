# ==============================================================================
# Markdown Manager — Production Environment Template
# ==============================================================================
# Copy to deployment/production.env and fill in actual values.
# NEVER commit production.env to version control.
#
# Usage: Referenced by docker-compose.prod.yml via env_file
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=markdown_manager
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
POSTGRES_DB=markdown_manager
DATABASE_URL=postgresql+asyncpg://markdown_manager:CHANGE_ME@db:5432/markdown_manager

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURE_COOKIES=true

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── Storage ──────────────────────────────────────────────────────────────────
MARKDOWN_STORAGE_ROOT=/documents

# ── Service URLs (internal Docker network) ───────────────────────────────────
EXPORT_SERVICE_URL=http://export:8001
MARKDOWN_LINT_SERVICE_URL=http://linting:8002
SPELL_CHECK_SERVICE_URL=http://spell-check:8003
EMBEDDING_SERVICE_URL=http://embedding:8005
OLLAMA_URL=http://ollama:11434

# ── ClamAV Virus Scanning ───────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://yourdomain.com/api/github/auth/callback
GITHUB_OAUTH_SCOPE=user,repo,read:org

# ── GitHub Repository Limits ─────────────────────────────────────────────────
GITHUB_MAX_REPOS_PER_ACCOUNT=20
GITHUB_MIN_UPDATED_DAYS=365
GITHUB_INCLUDE_FORKS=false
GITHUB_EXCLUDE_ARCHIVED=true
GITHUB_MAX_REPO_SIZE_MB=100
GITHUB_TOTAL_STORAGE_LIMIT_GB=5
GITHUB_CLONE_DEPTH=10
GITHUB_AUTO_PRUNE_DAYS=30
GITHUB_MARKDOWN_ONLY=false

# ── Event Publisher (Outbox Relay) ───────────────────────────────────────────
RELAY_DATABASE_URL=postgresql+asyncpg://markdown_manager:CHANGE_ME@db:5432/markdown_manager
RELAY_REDIS_URL=redis://redis:6379/0
RELAY_BATCH_SIZE=50
RELAY_POLL_INTERVAL=1.0
RELAY_MAX_RETRY_ATTEMPTS=3
RELAY_LOG_LEVEL=INFO

# ── Email (SMTP) ────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# FROM_EMAIL=noreply@yourdomain.com

# ── Export Service ───────────────────────────────────────────────────────────
DRAWIO_VERSION=24.7.5
DRAWIO_QUALITY_THRESHOLD=60.0

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Ollama LLM Tuning ───────────────────────────────────────────────────────
# Number of CPU threads for LLM inference (set to physical core count)
OLLAMA_NUM_THREAD=4